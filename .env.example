# Copy to `.env` (or set in your deploy env) and fill in real values.
# Anything left commented falls back to a safe default in code.

# ---------------------------------------------------------------------------
# Provider selection
# ---------------------------------------------------------------------------
# Which CaseProvider backs the generator. Default: gemini.
#   - gemini  : Google Gemini via google-genai SDK (current production).
#   - bedrock : AWS Bedrock (stub today; finalized at GovCloud onboarding).
#   - stub    : Deterministic in-process fake. Use in tests / dev without keys.
# CASE_PROVIDER=gemini

# Gemini provider — required when CASE_PROVIDER=gemini.
GEMINI_API_KEY=
# Per-request timeout (seconds). If Gemini stalls beyond this, asyncio.wait_for
# raises TimeoutError; the case_generator retry layer catches it and rolls
# into a fallback case. Default 60. Bump if you see widespread timeouts under
# normal load — but a stall longer than ~60s usually indicates an upstream
# incident, not a code-level fix.
# GEMINI_REQUEST_TIMEOUT_S=60

# Bedrock provider — required when CASE_PROVIDER=bedrock.
#
# AWS region. Use a commercial region (us-east-1 has every Anthropic model)
# while running in commercial AWS; switch to us-gov-west-1 for GovCloud.
# AWS_REGION=us-east-1
#
# Bedrock model identifier. REQUIRED — provider raises on first use if unset.
# Use the cross-region inference profile id when available (the `us.` prefix
# routes the request to the closest healthy region in the inference profile).
# Find the exact id in the AWS Bedrock console -> Model access.
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
#
# Optional knobs:
# BEDROCK_REQUEST_TIMEOUT_S=60       # per-request timeout (asyncio.wait_for)
# BEDROCK_MAX_OUTPUT_TOKENS=8192     # output token ceiling per call (cost knob)
# BEDROCK_TEMPERATURE=0.7            # generation temperature
#
# AWS credentials use boto3's standard chain: env vars (AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY / AWS_SESSION_TOKEN), instance role, ~/.aws/credentials.
# Required IAM action: bedrock:InvokeModel on the resolved model arn.

# ---------------------------------------------------------------------------
# Generation tuning
# ---------------------------------------------------------------------------
# Cases per LLM batch. Larger = fewer round trips, more tokens per call.
# CASE_BATCH_SIZE=5

# Concurrent in-flight batches per job. The job worker also serializes whole
# jobs via a global Semaphore(1), so concurrency only multiplies within one job.
# CASE_BATCH_CONCURRENCY=3

# ---------------------------------------------------------------------------
# Persistence
# ---------------------------------------------------------------------------
# Postgres connection string. If unset, the app runs DB-less:
#   - Exercises live only in-memory for the duration of a single sync request.
#   - Jobs use InMemoryJobStore (lost on restart).
#   - Matrix overrides use InMemoryMatrixStore (lost on restart).
# Both `postgres://` and `postgresql://` are accepted (the app normalizes).
# DATABASE_URL=postgresql://user:pass@host:5432/role2

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# LOG_LEVEL=INFO         # DEBUG, INFO, WARNING, ERROR
# LOG_FORMAT=json        # 'json' for log aggregators; default is human-readable.

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
# Public API base URL for the Next.js client. Set this to where the FastAPI
# backend is reachable from the browser.
# NEXT_PUBLIC_API_URL=https://role2-builder-production.up.railway.app
